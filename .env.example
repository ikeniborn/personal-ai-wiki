DATABASE_URL=postgresql+asyncpg://MASKING@postgres:5432/paw
REDIS_URL=redis://redis:6379/0
# 32+ byte random string for signing session ids. Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ---------------------------------------------------------------------------
# Observability (opt-in): docker compose --profile observability up
# cadvisor requires privileged mode — only enable on trusted hosts.
# ---------------------------------------------------------------------------
# Worker Prometheus metrics port; 0 disables it outside compose
WORKER_METRICS_PORT=9100
# Bearer token required to scrape /metrics.
# Empty/unset keeps the API endpoint disabled (404) for normal app usage.
# Must be non-empty when enabling --profile observability for Prometheus scraping.
METRICS_TOKEN=
# Required when running --profile observability (Grafana admin password)
GRAFANA_ADMIN_PASSWORD=

# --- Deploy (docker-compose) ---
# Postgres superuser password (compose default is "paw"; set a strong value in prod).
POSTGRES_PASSWORD=paw
# Email Let's Encrypt uses for ACME registration / expiry notices.
ACME_EMAIL=admin@example.com
# Public hostname Traefik routes to the api (must resolve to this host for ACME to issue certs).
PAW_HOST=localhost

# --- Backups (compose `backup` profile) ---
# Days to keep dumps before pruning.
BACKUP_RETENTION_DAYS=7
# Seconds between scheduled dumps (86400 = daily).
BACKUP_INTERVAL_SECONDS=86400
