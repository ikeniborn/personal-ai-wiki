{
  "title": "PAW Overview",
  "uid": "paw-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(paw_http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(paw_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(paw_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Job Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(paw_job_total[5m])) by (kind, status)",
          "legendFormat": "{{kind}} {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "LLM Cost (USD/hour)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(paw_llm_cost_usd_total[1h])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(paw_cache_hits_total{result=\"hit\"}[5m])) / sum(rate(paw_cache_hits_total[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    }
  ]
}
